# Main AI defaults for local development.
VITE_MAIN_AI_API_BASE=https://api.openai.com/v1
VITE_MAIN_AI_API_KEY=
VITE_MAIN_AI_MODEL=gpt-4o-mini

# Optional content AI overrides. Leave blank to reuse the main AI settings.
VITE_CONTENT_AI_API_BASE=
VITE_CONTENT_AI_API_KEY=
VITE_CONTENT_AI_MODEL=

# Backward-compatible aliases if you already use the older names.
# VITE_OPENAI_API_BASE=https://api.openai.com/v1
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o-mini
# VITE_AI_API_BASE=
# VITE_AI_API_KEY=
# VITE_AI_MODEL=

# Legacy Gemini key for services/geminiService.ts only.
# The current main dialogue flow uses the VITE_* defaults above.
# GEMINI_API_KEY=
