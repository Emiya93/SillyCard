{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite: run and debug in Edge",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm.cmd run dev -- --host 0.0.0.0 --port 3000 --strictPort",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://[^\\s]+)",
        "uriFormat": "%s",
        "action": "debugWithEdge"
      }
    },
    {
      "name": "Vite: attach Edge to localhost:3000",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
